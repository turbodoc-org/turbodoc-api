{
  "name": "turbodoc-api",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "migrate": "npx supabase migration up --linked",
    "gen-db-types": "npx supabase gen types typescript --linked --schema public > src/types/database.types.ts",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "prepare": "vp config"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "1.1.0",
    "@hono/swagger-ui": "0.6.1",
    "@supabase/supabase-js": "2.104.0",
    "chanfana": "2.8.1",
    "hono": "4.12.14",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@hono/vite-build": "1.11.1",
    "@hono/vite-dev-server": "0.25.3",
    "supabase": "2.93.1",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "wrangler": "4.84.1"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "onlyBuiltDependencies": [
      "supabase"
    ]
  }
}
